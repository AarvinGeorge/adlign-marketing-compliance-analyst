# snapshot-capture fallback fetcher credentials.
# Copy to .env and fill in. .env is gitignored; never commit real keys.
# crawl4ai (primary) needs no key — it renders locally via Playwright.
# These two are only used when crawl4ai returns thin/blocked/failed content.

HYPERBROWSER_API_KEY=your_hyperbrowser_api_key_here
APIFY_TOKEN=your_apify_token_here
